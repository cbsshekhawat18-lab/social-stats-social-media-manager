# ── Django ────────────────────────────────────────────────────────────────────
SECRET_KEY=your-secret-key-change-this-in-production
DEBUG=False
ALLOWED_HOSTS=socialstats.app,www.socialstats.app
FRONTEND_URL=https://socialstats.app

# ── Field-level encryption (Stage 1 security build-out) ──────────────────────
# Used by EncryptedTextField across the codebase to encrypt at rest:
#   - PlatformCredential.access_token / refresh_token
#   - ManualCredentialExtras.oauth_client_id / oauth_client_secret / api_key
#   - (later stages) UserMFA.totp_secret, APIKey.key_hash, …
#
# FIELD_ENCRYPTION_KEYS is a comma-separated list. The FIRST key is "primary"
# and used for new writes; every key in the list can decrypt. Add a new key
# at position [0] when rotating, run social_stats.security.tasks.rotate_encryption_keys,
# then drop the retired key on the next deploy.
#
# Generate a key:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#
# In production, store the comma-separated value in AWS Secrets Manager / Vault
# and inject at boot — never commit real keys to git.
#
# Backwards compat: if FIELD_ENCRYPTION_KEYS is empty, the legacy single-key
# var FIELD_ENCRYPTION_KEY is used; if that's also empty, SECRET_KEY is
# stretched (dev-only fallback — production must set FIELD_ENCRYPTION_KEYS).
FIELD_ENCRYPTION_KEYS=
FIELD_ENCRYPTION_KEY=

# ── Database (default: SQLite for dev, use PostgreSQL for production) ─────────
DATABASE_URL=postgres://xperso_user:YourStrongPassword@localhost:5432/xperso_db
# or use separate vars (DB_NAME/DB_USER/etc)


# ── Redis (required for Celery auto-sync) ─────────────────────────────────────
# Install Redis: https://redis.io/docs/getting-started/
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ─────────────────────────────────────────────────────────────────────────────
# META (Facebook + Instagram)
# ─────────────────────────────────────────────────────────────────────────────
# HOW TO GET:
#   1. Go to https://developers.facebook.com → Create App → Business type
#   2. Add products: Pages API + Instagram Graph API
#   3. Settings → Basic → copy App ID and App Secret
#   4. In App → Facebook Login → Settings → add Redirect URI below
META_APP_ID=your_meta_app_id_here
META_APP_SECRET=your_meta_app_secret_here
META_REDIRECT_URI=http://localhost:8000/api/oauth/facebook/callback/

# ─────────────────────────────────────────────────────────────────────────────
# GOOGLE (YouTube + Google My Business)
# ─────────────────────────────────────────────────────────────────────────────
# HOW TO GET:
#   1. Go to https://console.cloud.google.com → New Project
#   2. APIs & Services → Enable:
#      - YouTube Data API v3
#      - YouTube Analytics API
#      - Business Profile API
#   3. APIs & Services → Credentials → Create OAuth 2.0 Client ID
#      - Type: Web Application
#      - Add Authorized redirect URI below
#   4. Copy Client ID and Client Secret
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/oauth/google/callback/

# ─────────────────────────────────────────────────────────────────────────────
# LINKEDIN
# ─────────────────────────────────────────────────────────────────────────────
# HOW TO GET:
#   1. Go to https://www.linkedin.com/developers → Create App
#   2. Associate with your company LinkedIn page
#   3. Products tab → Request "Marketing Developer Platform" (1-5 days approval)
#   4. Auth tab → copy Client ID and Client Secret
#   5. Add redirect URI below in OAuth 2.0 settings
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
LINKEDIN_REDIRECT_URI=http://localhost:8000/api/oauth/linkedin/callback/

# ─────────────────────────────────────────────────────────────────────────────
# EMAIL (for sending reports to clients)
# ─────────────────────────────────────────────────────────────────────────────
# Use Gmail: enable 2FA → App Passwords → generate password
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your@gmail.com
EMAIL_HOST_PASSWORD=your_app_password
DEFAULT_FROM_EMAIL=reports@youragency.com

# ─────────────────────────────────────────────────────────────────────────────
# ANTHROPIC (AI-Powered Insights)
# ─────────────────────────────────────────────────────────────────────────────
# HOW TO GET:
#   1. Go to https://console.anthropic.com → API Keys → Create Key
ANTHROPIC_API_KEY=sk-ant-api03-your_anthropic_api_key_here

# ─────────────────────────────────────────────────────────────────────────────
# WHATSAPP (Pinbot Partners API v3)
# ─────────────────────────────────────────────────────────────────────────────
# HOW TO GET:
#   1. Sign up at https://pinbot.ai (Partners account)
#   2. Provision a WABA (WhatsApp Business Account) per Social Stats client
#   3. Get the apikey from your Pinbot dashboard
#   4. WHATSAPP_ENCRYPTION_KEY: generate with:
#        python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#   5. WHATSAPP_WEBHOOK_SECRET: random 32+ char string used to verify Pinbot
#      webhook calls hitting /api/whatsapp/webhook/
PINBOT_BASE_URL=https://partnersv1.pinbot.ai/v3
WHATSAPP_ENCRYPTION_KEY=
WHATSAPP_WEBHOOK_SECRET=
WHATSAPP_RATE_LIMIT_PER_SEC=20

# ─────────────────────────────────────────────────────────────────────────────
# OAUTH APPS APPROVED FLAG
# ─────────────────────────────────────────────────────────────────────────────
# False (default) → Quick Connect buttons are disabled in the UI and labelled
#   "Coming Soon"; users are directed to the Manual Setup wizard instead.
# True → Quick Connect (OAuth) is re-enabled. Flip this once Meta and Google
#   have approved the Social Stats OAuth apps in production.
OAUTH_APPS_APPROVED=False
